# ocaml_write_safety.rules
# Technology: ocaml | Capability: write

rule ocaml-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "Obj.magic"
  MESSAGE "Blocked an unsafe pattern in ocaml. Use the recommended best practices for 2025/2026."
}

rule ocaml-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "Pervasives"
  MESSAGE "You are using an outdated API for ocaml. Please upgrade to the newer API."
}
